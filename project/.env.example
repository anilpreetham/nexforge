# Copy to .env and fill in real values. NEVER commit .env.
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
DATABASE_URL=postgres://nexforge:pass@localhost:5432/nexforge
# Dev only: local Postgres used by config.settings.dev (never the shared DB).
# Matches the docker one-liner in the README. Leave unset to use the default.
DEV_DATABASE_URL=postgres://nexforge:nexforge@localhost:5432/nexforge

# JWT token lifetimes (optional; sensible defaults in settings)
ACCESS_TOKEN_LIFETIME=15
REFRESH_TOKEN_LIFETIME=7

# Email (dev uses console backend; these matter in prod)
EMAIL_HOST=smtp.example.com
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@nexforgeautomation.com
SALES_INBOX=sales@nexforgeautomation.com
HR_INBOX=careers@nexforgeautomation.com

# Google Maps (optional, for location embeds)
GOOGLE_MAPS_API_KEY=

# Google Analytics 4 (optional, for visitor tracking). e.g. G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=

# Hero background video (optional). Static path or https URL; empty = animated graphic only.
HERO_VIDEO_URL=
HERO_VIDEO_POSTER=

# Production only
CORS_ALLOWED_ORIGINS=https://nexforgeautomation.com

# Sentry (optional but recommended)
SENTRY_DSN=

# CSP Report-only mode for testing (set to 'False' to enforce)
CSP_REPORT_ONLY=True